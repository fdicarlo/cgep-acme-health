{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TerraformStateBackend",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketVersioning",
        "s3:GetEncryptionConfiguration"
      ],
      "Resource": [
        "arn:aws:s3:::cgep-acme-health-tfstate-491919374738-us-east-1",
        "arn:aws:s3:::cgep-acme-health-tfstate-491919374738-us-east-1/*"
      ]
    },
    {
      "Sid": "TerraformStateLocking",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:DeleteItem",
        "dynamodb:DescribeTable"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:491919374738:table/cgep-acme-health-tf-locks"
    },
    {
      "Sid": "AcmeS3Buckets",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::acme-health-intake-*",
        "arn:aws:s3:::acme-health-intake-*/*"
      ]
    },
    {
      "Sid": "AcmeDynamoDbTables",
      "Effect": "Allow",
      "Action": "dynamodb:*",
      "Resource": "arn:aws:dynamodb:us-east-1:491919374738:table/acme-health-intake-*"
    },
    {
      "Sid": "AcmeKmsKeys",
      "Effect": "Allow",
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "AcmeCloudTrailAndLogs",
      "Effect": "Allow",
      "Action": [
        "cloudtrail:*",
        "logs:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AcmeNetworkAndLambda",
      "Effect": "Allow",
      "Action": [
        "ec2:*",
        "lambda:*",
        "apigateway:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AcmeIamRolesAndPolicies",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:PassRole",
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicyVersions",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:ListRolePolicies"
      ],
      "Resource": [
        "arn:aws:iam::491919374738:role/acme-health-intake-*",
        "arn:aws:iam::491919374738:policy/acme-health-intake-*",
        "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole",
        "arn:aws:iam::aws:policy/service-role/AWSLambdaVPCAccessExecutionRole"
      ]
    },
    {
      "Sid": "ReadOnlyDiscovery",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity",
        "tag:GetResources",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:ListPolicyVersions",
        "iam:ListRoles",
        "iam:ListPolicies",
        "cloudwatch:DescribeAlarms",
        "events:ListRules",
        "events:ListTargetsByRule"
      ],
      "Resource": "*"
    }
  ]
}
